// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`miko CLI help-text snapshots every documented command emits stable help text: miko acp --help 1`] = `
"miko acp

start ACP (Agent Client Protocol) server

Options:
  -h, --help         show help                                                             [boolean]
  -v, --version      show version number                                                   [boolean]
      --print-logs   print logs to stderr                                                  [boolean]
      --log-level    log level                  [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure         run without external plugins                                          [boolean]
      --port         port to listen on                                         [number] [default: 0]
      --hostname     hostname to listen on                           [string] [default: "127.0.0.1"]
      --mdns         enable mDNS service discovery (defaults hostname to 0.0.0.0)
                                                                          [boolean] [default: false]
      --mdns-domain  custom domain name for mDNS service (default: miko.local)
                                                                    [string] [default: "miko.local"]
      --cors         additional domains to allow for CORS                      [array] [default: []]
      --cwd          working directory [string] [default: "<HOME>"]"
`;

exports[`miko CLI help-text snapshots every documented command emits stable help text: miko mcp --help 1`] = `
"miko mcp

manage MCP (Model Context Protocol) servers

Commands:
  miko mcp add [name]     add an MCP server
  miko mcp list           list MCP servers and their status                            [aliases: ls]
  miko mcp auth [name]    authenticate with an OAuth-enabled MCP server
  miko mcp logout [name]  remove OAuth credentials for an MCP server
  miko mcp debug <name>   debug OAuth connection for an MCP server

Options:
  -h, --help        show help                                                              [boolean]
  -v, --version     show version number                                                    [boolean]
      --print-logs  print logs to stderr                                                   [boolean]
      --log-level   log level                   [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure        run without external plugins                                           [boolean]"
`;

exports[`miko CLI help-text snapshots every documented command emits stable help text: miko attach --help 1`] = `
"miko attach <url>

attach to a running miko server

Positionals:
  url  http://localhost:4096                                                     [string] [required]

Options:
  -h, --help        show help                                                              [boolean]
  -v, --version     show version number                                                    [boolean]
      --print-logs  print logs to stderr                                                   [boolean]
      --log-level   log level                   [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure        run without external plugins                                           [boolean]
      --dir         directory to run in                                                     [string]
  -c, --continue    continue the last session                                              [boolean]
  -s, --session     session id to continue                                                  [string]
      --fork        fork the session when continuing (use with --continue or --session)    [boolean]
  -p, --password    basic auth password (defaults to MIKO_SERVER_PASSWORD)                  [string]
  -u, --username    basic auth username (defaults to MIKO_SERVER_USERNAME or 'miko')        [string]"
`;

exports[`miko CLI help-text snapshots every documented command emits stable help text: miko run --help 1`] = `
"miko run [message..]

run miko with a message

Positionals:
  message  message to send                                                     [array] [default: []]

Options:
  -h, --help                          show help                                            [boolean]
  -v, --version                       show version number                                  [boolean]
      --print-logs                    print logs to stderr                                 [boolean]
      --log-level                     log level [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure                          run without external plugins                         [boolean]
      --command                       the command to run, use message for args              [string]
  -c, --continue                      continue the last session                            [boolean]
  -s, --session                       session id to continue                                [string]
      --fork                          fork the session before continuing (requires --continue or
                                      --session)                                           [boolean]
      --share                         share the session                                    [boolean]
  -m, --model                         model to use in the format of provider/model          [string]
      --agent                         agent to use                                          [string]
      --format                        format: default (formatted) or json (raw JSON events)
                                          [string] [choices: "default", "json"] [default: "default"]
  -f, --file                          file(s) to attach to message                           [array]
      --title                         title for the session (uses truncated prompt if no value
                                      provided)                                             [string]
      --attach                        attach to a running miko server (e.g., http://localhost:4096)
                                                                                            [string]
  -p, --password                      basic auth password (defaults to MIKO_SERVER_PASSWORD)[string]
  -u, --username                      basic auth username (defaults to MIKO_SERVER_USERNAME or
                                      'miko')                                               [string]
      --dir                           directory to run in, path on remote server if attaching
                                                                                            [string]
      --port                          port for the local server (defaults to random port if no value
                                      provided)                                             [number]
      --variant                       model variant (provider-specific reasoning effort, e.g., high,
                                      max, minimal)                                         [string]
      --thinking                      show thinking blocks                                 [boolean]
      --replay                        replay visible session history on interactive resume
                                                                          [boolean] [default: false]
      --replay-limit                  cap visible interactive replay to the newest N messages
                                                                                            [number]
  -i, --interactive                   run in direct interactive split-footer mode
                                                                          [boolean] [default: false]
      --dangerously-skip-permissions  auto-approve permissions that are not explicitly denied
                                      (dangerous!)                        [boolean] [default: false]
      --demo                          enable direct interactive demo slash commands; pass one as the
                                      message to run it immediately       [boolean] [default: false]"
`;

exports[`miko CLI help-text snapshots every documented command emits stable help text: miko debug --help 1`] = `
"miko debug

debugging and troubleshooting tools

Commands:
  miko debug config        show resolved configuration
  miko debug lsp           LSP debugging utilities
  miko debug rg            ripgrep debugging utilities
  miko debug file          file system debugging utilities
  miko debug scrap         list all known projects
  miko debug skill         list all available skills
  miko debug snapshot      snapshot debugging utilities
  miko debug startup       print startup timing
  miko debug agent <name>  show agent configuration details
  miko debug v2            debug v2 catalog and built-in plugins
  miko debug info          show debug information
  miko debug paths         show global paths (data, config, cache, state)
  miko debug wait          wait indefinitely (for debugging)

Options:
  -h, --help        show help                                                              [boolean]
  -v, --version     show version number                                                    [boolean]
      --print-logs  print logs to stderr                                                   [boolean]
      --log-level   log level                   [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure        run without external plugins                                           [boolean]"
`;

